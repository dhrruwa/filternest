# Server Configuration
PORT=5001
NODE_ENV=development

# Database - Supabase (PostgreSQL via Prisma)
# Get these from: Supabase Dashboard -> Connect -> ORMs -> Prisma
# DATABASE_URL = pooled connection (port 6543, ends with ?pgbouncer=true) used at runtime
# DIRECT_URL   = direct connection (port 5432) used by Prisma Migrate
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@<region>.pooler.supabase.com:5432/postgres"

# JWT (BOTH are required — the server refuses to start without them)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret
JWT_EXPIRE=7d

# Default admin (seeded on startup in development).
# Seeding is SKIPPED if ADMIN_EMAIL or ADMIN_PASSWORD is empty.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_to_a_strong_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PHONE=+910000000000

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# API / Frontend URLs
API_URL=http://localhost:5001/api
FRONTEND_URL=http://localhost:3000
# Allowed browser origins for CORS + CSRF (comma-separated, exact origins only)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:6001

# MSG91 OTP Configuration
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
